# Required: MongoDB connection string used by src/lib/db.ts
MONGODB_URI=mongodb://127.0.0.1:27017/bookify

# Optional: app URL for links/callbacks in local development
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Required for Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Required for Vapi assistant creation
VAPI_API_KEY=
VAPI_VOICE_ID_MALE_PROFESSIONAL=
VAPI_VOICE_ID_FEMALE_FRIENDLY=
VAPI_VOICE_ID_MALE_SOFT=
VAPI_VOICE_ID_FEMALE_DEEP=

# Optional: node env
NODE_ENV=development

# Required for book upload S3 flow (AWS_REGION must match the bucket’s region, e.g. us-east-1)
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: if using CloudFront/custom domain for S3 objects
AWS_S3_PUBLIC_BASE_URL=

# Required for Gemini metadata extraction
# Use a model your API key can call (1.5-flash often 404 on v1beta; 2.0-flash is typical default)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_QUERY_MODEL=gemini-2.0-flash

# Required for Inngest (SDK-based, no more raw HTTP)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Required for NeonDB (pgVector storage)
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/bookfy?sslmode=require
